    "privacySecurityIntro": "We at the Expense Manager app value your privacy and the security of your financial and personal data. By using the app, you agree to the following privacy policy:",
    "@privacySecurityIntro": {
        "description": "Introduction text for the privacy and security screen"
    },
    "privacySecurityFirstTitle": "1. Data We Collect",
    "@privacySecurityFirstTitle": {
        "description": "Title for the first section of the privacy and security screen"
    },
    "privacySecurityFirstText": "• Information you manually enter into the app (such as expenses, categories, income...)\n• User account information (name, email, password) if you create an account.\n• We do not collect any other data without your knowledge or consent.",
    "@privacySecurityFirstText": {
        "description": "Text for the first section of the privacy and security screen"
    },
    "privacySecuritySecondTitle": "2. Data Storage Location",
    "@privacySecuritySecondTitle": {
        "description": "Title for the second section of the privacy and security screen"
    },
    "privacySecuritySecondText": "• If you don’t have an account: your data is stored locally on your device only.\n• If you create an account: a secure copy of your data is stored online to enable synchronization and recovery from other devices.\n• Data is encrypted during transfer and storage for your safety.",
    "@privacySecuritySecondText": {
        "description": "Text for the second section of the privacy and security screen"
    },
    "privacySecurityThirdTitle": "3. How We Use Data",
    "@privacySecurityThirdTitle": {
        "description": "Title for the third section of the privacy and security screen"
    },
    "privacySecurityThirdText": "• Your data is only used to display and manage your personal expenses.\n• We do not share your data with third parties.\n• We do not use your data for advertising or marketing purposes.",
    "@privacySecurityThirdText": {
        "description": "Text for the third section of the privacy and security screen"
    },
    "privacySecurityFourthTitle": "4. Security",
    "@privacySecurityFourthTitle": {
        "description": "Title for the fourth section of the privacy and security screen"
    },
    "privacySecurityFourthText": "• All stored data, locally or on the server, is protected using encryption technologies.\n• You can change your password anytime from account settings.\n• You can permanently delete your account and all related data.\n• App access can be protected using a PIN or fingerprint (if supported).",
    "@privacySecurityFourthText": {
        "description": "Text for the fourth section of the privacy and security screen"
    },
    "privacySecurityFifthTitle": "5. User Rights",
    "@privacySecurityFifthTitle": {
        "description": "Title for the fifth section of the privacy and security screen"
    },
    "privacySecurityFifthText": "• You have full rights to access, modify, or delete your data.\n• You can use the 'Delete Account' feature to permanently erase all data from the app and the server.",
    "@privacySecurityFifthText": {
        "description": "Text for the fifth section of the privacy and security screen"
    },
